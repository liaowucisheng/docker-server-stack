# =============================================================================
# 服务器环境变量 —— 示例文件
# 复制此文件为 .env 并修改所有密码
# =============================================================================
# cp .env.example .env && chmod 600 .env

# =====================================
# 基础配置
# =====================================

# Docker Compose项目名称
COMPOSE_PROJECT_NAME=liaowucisheng-server

# Docker容器时区
TZ=Asia/Shanghai


# =====================================
# PostgreSQL
# =====================================

# PostgreSQL管理员账号,，建议修改
POSTGRES_USER=postgres

# 修改为强密码
POSTGRES_PASSWORD=change_me


# =====================================
# Gitea
# =====================================

# Git服务访问域名
# 需要提前配置DNS解析
GITEA_DOMAIN=git.example.com


# SSH访问端口
# Gitea SSH 外部端口， 用于 git clone ssh，建议修改，防止与服务器SSH的22端口冲突
GITEA_SSH_PORT=2222


# Gitea独立数据库
GITEA_DB_NAME=giteadb
GITEA_DB_USER=gitea
GITEA_DB_PASSWORD=change_me


# 首次启动创建管理员
GITEA_ADMIN_USER=admin
GITEA_ADMIN_PASSWORD=change_me
GITEA_ADMIN_EMAIL=admin@example.com


# =====================================
# Nginx Proxy Manager
# =====================================

# HTTP
NPM_HTTP_PORT=80

# HTTPS
NPM_HTTPS_PORT=443

# 管理后台
# 只绑定127.0.0.1
NPM_ADMIN_PORT=81


# =====================================
# Code Server
# =====================================

CODE_SERVER_PASSWORD=change_me